<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Quotation: multi-company rule -->
        <record id="rule_quotation_company" model="ir.rule">
            <field name="name">Devis : par société</field>
            <field name="model_id" ref="model_garage_quotation"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Repair Order: multi-company rule -->
        <record id="rule_repair_order_company" model="ir.rule">
            <field name="name">OR : par société</field>
            <field name="model_id" ref="model_garage_repair_order"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Subcontract Order: multi-company rule -->
        <record id="rule_subcontract_company" model="ir.rule">
            <field name="name">Sous-traitance : par société</field>
            <field name="model_id" ref="model_garage_subcontract_order"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
