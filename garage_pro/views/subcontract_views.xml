<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- SOUS-TRAITANCE — Form                                        -->
    <!-- ============================================================ -->
    <record id="garage_subcontract_order_form" model="ir.ui.view">
        <field name="name">garage.subcontract.order.form</field>
        <field name="model">garage.subcontract.order</field>
        <field name="arch" type="xml">
            <form string="Bon de sous-traitance">
                <header>
                    <button name="action_send" type="object"
                            string="Envoyer" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start" type="object"
                            string="En cours" class="btn-primary"
                            invisible="state != 'sent'"/>
                    <button name="action_done" type="object"
                            string="Terminé" class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_invoice" type="object"
                            string="Facturé"
                            invisible="state != 'done'"/>
                    <button name="action_cancel" type="object"
                            string="Annuler"
                            invisible="state in ('done', 'invoiced', 'cancelled')"/>
                    <button name="action_reset" type="object"
                            string="Remettre en brouillon"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,sent,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Général">
                            <field name="repair_order_id"/>
                            <field name="vehicle_id"/>
                            <field name="subcontractor_id"/>
                            <field name="service_type"/>
                            <field name="send_type"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group string="Coûts &amp; Dates">
                            <field name="estimated_cost"/>
                            <field name="actual_cost"/>
                            <field name="send_date"/>
                            <field name="expected_return_date"/>
                            <field name="actual_return_date"/>
                            <field name="is_late" invisible="not is_late"/>
                            <field name="purchase_order_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="page_description">
                            <field name="description"
                                   placeholder="Description détaillée des travaux à sous-traiter..."/>
                        </page>
                        <page string="Qualité" name="page_quality">
                            <group>
                                <field name="quality_ok"/>
                                <field name="quality_notes"
                                       placeholder="Notes sur la qualité du travail reçu..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- SOUS-TRAITANCE — Tree -->
    <record id="garage_subcontract_order_tree" model="ir.ui.view">
        <field name="name">garage.subcontract.order.tree</field>
        <field name="model">garage.subcontract.order</field>
        <field name="arch" type="xml">
            <tree string="Bons de sous-traitance"
                  decoration-danger="is_late"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="repair_order_id"/>
                <field name="vehicle_id"/>
                <field name="subcontractor_id"/>
                <field name="service_type"/>
                <field name="estimated_cost"/>
                <field name="actual_cost" optional="show"/>
                <field name="expected_return_date"/>
                <field name="is_late" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('draft', 'sent')"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state in ('done', 'invoiced')"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- SOUS-TRAITANCE — Search -->
    <record id="garage_subcontract_order_search" model="ir.ui.view">
        <field name="name">garage.subcontract.order.search</field>
        <field name="model">garage.subcontract.order</field>
        <field name="arch" type="xml">
            <search string="Sous-traitance">
                <field name="name"/>
                <field name="repair_order_id"/>
                <field name="subcontractor_id"/>
                <separator/>
                <filter string="En retard" name="filter_late"
                        domain="[('is_late', '=', True)]"/>
                <filter string="En cours" name="filter_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="À facturer" name="filter_to_invoice"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Sous-traitant" name="group_subcontractor"
                            context="{'group_by': 'subcontractor_id'}"/>
                    <filter string="Type de service" name="group_service"
                            context="{'group_by': 'service_type'}"/>
                    <filter string="Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- SOUS-TRAITANCE — Action -->
    <record id="garage_subcontract_order_action" model="ir.actions.act_window">
        <field name="name">Sous-traitance</field>
        <field name="res_model">garage.subcontract.order</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer un bon de sous-traitance
            </p>
            <p>
                PDR, vitrage, sellerie, calibration ADAS, géométrie…
            </p>
        </field>
    </record>

</odoo>
