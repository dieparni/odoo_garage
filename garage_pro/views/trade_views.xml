<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- CARROSSERIE — Form                                           -->
    <!-- ============================================================ -->
    <record id="garage_bodywork_operation_form" model="ir.ui.view">
        <field name="name">garage.bodywork.operation.form</field>
        <field name="model">garage.bodywork.operation</field>
        <field name="arch" type="xml">
            <form string="Opération carrosserie">
                <header>
                    <button name="action_start" type="object"
                            string="Démarrer" class="btn-primary"
                            invisible="state != 'todo'"/>
                    <button name="action_done" type="object"
                            string="Terminer" class="btn-primary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_block" type="object"
                            string="Bloquer"
                            invisible="state not in ('todo', 'in_progress')"/>
                    <button name="action_unblock" type="object"
                            string="Débloquer"
                            invisible="state != 'blocked'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="todo,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Opération">
                            <field name="name"/>
                            <field name="operation_type"/>
                            <field name="damage_zone"/>
                            <field name="damage_level"/>
                            <field name="requires_painting"/>
                            <field name="paint_operation_id"
                                   invisible="not paint_operation_id"/>
                        </group>
                        <group string="Exécution">
                            <field name="repair_order_id"/>
                            <field name="ro_line_id"/>
                            <field name="technician_id"/>
                            <field name="allocated_time"/>
                            <field name="actual_time"/>
                            <field name="blocked_reason"
                                   invisible="state != 'blocked'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Photos" name="page_photos">
                            <group>
                                <field name="photo_before_ids" widget="many2many_binary"/>
                                <field name="photo_after_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                        <page string="Notes" name="page_notes">
                            <field name="notes" placeholder="Notes techniques..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- CARROSSERIE — Tree -->
    <record id="garage_bodywork_operation_tree" model="ir.ui.view">
        <field name="name">garage.bodywork.operation.tree</field>
        <field name="model">garage.bodywork.operation</field>
        <field name="arch" type="xml">
            <tree string="Opérations carrosserie"
                  decoration-success="state == 'done'"
                  decoration-danger="state == 'blocked'">
                <field name="repair_order_id"/>
                <field name="name"/>
                <field name="operation_type"/>
                <field name="damage_zone"/>
                <field name="damage_level"/>
                <field name="technician_id"/>
                <field name="allocated_time" sum="Total alloué"/>
                <field name="actual_time" sum="Total réel"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'todo'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'blocked'"/>
            </tree>
        </field>
    </record>

    <!-- CARROSSERIE — Search -->
    <record id="garage_bodywork_operation_search" model="ir.ui.view">
        <field name="name">garage.bodywork.operation.search</field>
        <field name="model">garage.bodywork.operation</field>
        <field name="arch" type="xml">
            <search string="Opérations carrosserie">
                <field name="name"/>
                <field name="repair_order_id"/>
                <field name="technician_id"/>
                <separator/>
                <filter string="À faire" name="filter_todo"
                        domain="[('state', '=', 'todo')]"/>
                <filter string="En cours" name="filter_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Bloqué" name="filter_blocked"
                        domain="[('state', '=', 'blocked')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="OR" name="group_ro"
                            context="{'group_by': 'repair_order_id'}"/>
                    <filter string="Statut" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Carrossier" name="group_tech"
                            context="{'group_by': 'technician_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- CARROSSERIE — Kanban -->
    <record id="garage_bodywork_operation_kanban" model="ir.ui.view">
        <field name="name">garage.bodywork.operation.kanban</field>
        <field name="model">garage.bodywork.operation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="repair_order_id"/>
                <field name="technician_id"/>
                <field name="damage_zone"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="name"/></strong>
                                <div><field name="repair_order_id"/></div>
                                <div class="text-muted" t-if="record.technician_id.value">
                                    <i class="fa fa-user" title="Technicien"/> <field name="technician_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- CARROSSERIE — Action -->
    <record id="garage_bodywork_operation_action" model="ir.actions.act_window">
        <field name="name">Carrosserie</field>
        <field name="res_model">garage.bodywork.operation</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_filter_todo': 1, 'search_default_filter_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune opération de carrosserie
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- PEINTURE — Form                                              -->
    <!-- ============================================================ -->
    <record id="garage_paint_operation_form" model="ir.ui.view">
        <field name="name">garage.paint.operation.form</field>
        <field name="model">garage.paint.operation</field>
        <field name="arch" type="xml">
            <form string="Opération peinture">
                <header>
                    <button name="action_start_prep" type="object"
                            string="Préparation" class="btn-primary"
                            invisible="state != 'waiting'"/>
                    <button name="action_enter_booth" type="object"
                            string="Cabine" class="btn-primary"
                            invisible="state != 'prep'"/>
                    <button name="action_drying" type="object"
                            string="Séchage"
                            invisible="state != 'booth'"/>
                    <button name="action_polish" type="object"
                            string="Polissage"
                            invisible="state != 'drying'"/>
                    <button name="action_done" type="object"
                            string="Terminer" class="btn-primary"
                            invisible="state != 'polish'"/>
                    <button name="action_rework" type="object"
                            string="Reprise"
                            invisible="state not in ('polish', 'done')"/>
                    <button name="action_restart" type="object"
                            string="Reprendre préparation"
                            invisible="state != 'rework'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="waiting,prep,booth,drying,polish,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Opération">
                            <field name="name"/>
                            <field name="operation_type"/>
                            <field name="zone"/>
                            <field name="bodywork_operation_id"/>
                        </group>
                        <group string="Teinte">
                            <field name="repair_order_id"/>
                            <field name="paint_code"/>
                            <field name="paint_system_id"/>
                            <field name="formula_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Cabine">
                            <field name="booth_slot_start"/>
                            <field name="booth_slot_end"/>
                            <field name="booth_temperature"/>
                            <field name="booth_humidity"/>
                        </group>
                        <group string="Exécution">
                            <field name="technician_id"/>
                            <field name="allocated_time"/>
                            <field name="actual_time"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_product_cost"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Consommation produits" name="page_consumption">
                            <field name="product_consumption_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_type"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="unit_cost"/>
                                    <field name="total_cost" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes qualité" name="page_notes">
                            <field name="quality_notes"
                                   placeholder="Notes qualité peinture..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- PEINTURE — Tree -->
    <record id="garage_paint_operation_tree" model="ir.ui.view">
        <field name="name">garage.paint.operation.tree</field>
        <field name="model">garage.paint.operation</field>
        <field name="arch" type="xml">
            <tree string="Opérations peinture"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'rework'">
                <field name="repair_order_id"/>
                <field name="name"/>
                <field name="operation_type"/>
                <field name="zone"/>
                <field name="technician_id"/>
                <field name="allocated_time" sum="Total alloué"/>
                <field name="actual_time" sum="Total réel"/>
                <field name="total_product_cost" sum="Coût produits"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'waiting'"
                       decoration-warning="state in ('prep', 'booth', 'drying', 'polish')"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'rework'"/>
            </tree>
        </field>
    </record>

    <!-- PEINTURE — Search -->
    <record id="garage_paint_operation_search" model="ir.ui.view">
        <field name="name">garage.paint.operation.search</field>
