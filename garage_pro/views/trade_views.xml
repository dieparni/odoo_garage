                <filter string="En cabine" name="filter_booth"
                        domain="[('state', '=', 'booth')]"/>
                <filter string="Reprise" name="filter_rework"
                        domain="[('state', '=', 'rework')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="OR" name="group_ro"
