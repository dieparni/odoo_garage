        <field name="name">Mécanique</field>
        <field name="res_model">garage.mechanic.operation</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_filter_todo': 1, 'search_default_filter_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune opération mécanique
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- PLAN D'ENTRETIEN — Form / Tree                               -->
    <!-- ============================================================ -->
    <record id="garage_maintenance_plan_form" model="ir.ui.view">
        <field name="name">garage.maintenance.plan.form</field>
        <field name="model">garage.maintenance.plan</field>
        <field name="arch" type="xml">
            <form string="Plan d'entretien">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <field name="vehicle_id"/>
                    </group>
                    <field name="item_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="interval_km"/>
                            <field name="interval_months"/>
                            <field name="last_done_km"/>
                            <field name="last_done_date"/>
                            <field name="next_due_km"/>
                            <field name="next_due_date"/>
                            <field name="is_overdue" widget="boolean_toggle"/>
                        </tree>
                    </field>
                    <group>
                        <field name="notes" placeholder="Notes constructeur..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="garage_maintenance_plan_tree" model="ir.ui.view">
        <field name="name">garage.maintenance.plan.tree</field>
        <field name="model">garage.maintenance.plan</field>
        <field name="arch" type="xml">
            <tree string="Plans d'entretien">
                <field name="vehicle_id"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="garage_maintenance_plan_action" model="ir.actions.act_window">
        <field name="name">Plans d'entretien</field>
        <field name="res_model">garage.maintenance.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun plan d'entretien
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Inherit OR form : ajouter onglets métier                     -->
    <!-- ============================================================ -->
    <record id="garage_repair_order_form_inherit_trades" model="ir.ui.view">
        <field name="name">garage.repair.order.form.inherit.trades</field>
        <field name="model">garage.repair.order</field>
        <field name="inherit_id" ref="garage_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_notes']" position="before">
                <page string="Carrosserie" name="page_bodywork">
                    <field name="bodywork_operation_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="operation_type"/>
                            <field name="damage_zone"/>
                            <field name="damage_level"/>
                            <field name="technician_id"/>
                            <field name="allocated_time" sum="Total"/>
                            <field name="actual_time" sum="Total"/>
                            <field name="requires_painting"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'todo'"
                                   decoration-warning="state == 'in_progress'"
                                   decoration-success="state == 'done'"
                                   decoration-danger="state == 'blocked'"/>
                        </tree>
                    </field>
                </page>
                <page string="Peinture" name="page_paint">
                    <field name="paint_operation_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="operation_type"/>
                            <field name="zone"/>
                            <field name="technician_id"/>
                            <field name="allocated_time" sum="Total"/>
                            <field name="actual_time" sum="Total"/>
                            <field name="total_product_cost" sum="Coût"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'waiting'"
                                   decoration-warning="state in ('prep', 'booth', 'drying', 'polish')"
                                   decoration-success="state == 'done'"
                                   decoration-danger="state == 'rework'"/>
                            <field name="currency_id" column_invisible="1"/>
                        </tree>
                    </field>
                </page>
                <page string="Mécanique" name="page_mechanic">
                    <field name="mechanic_operation_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="operation_category"/>
                            <field name="operation_type"/>
                            <field name="technician_id"/>
                            <field name="allocated_time" sum="Total"/>
                            <field name="actual_time" sum="Total"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'todo'"
                                   decoration-warning="state in ('in_progress', 'waiting_parts')"
                                   decoration-success="state == 'done'"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
