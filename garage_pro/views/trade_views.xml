                <field name="name"/>
                <field name="operation_category"/>
                <field name="operation_type"/>
                <field name="technician_id"/>
                <field name="allocated_time" sum="Total alloué"/>
                <field name="actual_time" sum="Total réel"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'todo'"
                       decoration-warning="state in ('in_progress', 'waiting_parts')"
                       decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

