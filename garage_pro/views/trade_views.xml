    <!-- PEINTURE — Action -->
    <record id="garage_paint_operation_action" model="ir.actions.act_window">
        <field name="name">Peinture</field>
        <field name="res_model">garage.paint.operation</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune opération de peinture
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- FORMULE PEINTURE — Form / Tree                               -->
    <!-- ============================================================ -->
    <record id="garage_paint_formula_form" model="ir.ui.view">
        <field name="name">garage.paint.formula.form</field>
        <field name="model">garage.paint.formula</field>
        <field name="arch" type="xml">
            <form string="Formule peinture">
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="paint_code"/>
                            <field name="paint_system_id"/>
                            <field name="formula_reference"/>
                            <field name="variant_name"/>
                            <field name="vehicle_id"/>
                        </group>
                        <group string="Spectrophotomètre">
                            <field name="spectro_date"/>
                            <field name="spectro_result" filename="spectro_file"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Détail formule">
                        <field name="formula_detail" nolabel="1"
                               placeholder="Composition : bases, quantités, ratios de mélange..."/>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Ajustements, remarques..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="garage_paint_formula_tree" model="ir.ui.view">
        <field name="name">garage.paint.formula.tree</field>
        <field name="model">garage.paint.formula</field>
        <field name="arch" type="xml">
            <tree string="Formules peinture">
                <field name="paint_code"/>
                <field name="paint_system_id"/>
                <field name="formula_reference"/>
                <field name="variant_name"/>
                <field name="vehicle_id"/>
                <field name="spectro_date"/>
            </tree>
        </field>
    </record>

    <record id="garage_paint_formula_action" model="ir.actions.act_window">
        <field name="name">Formules peinture</field>
        <field name="res_model">garage.paint.formula</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune formule peinture enregistrée
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- MÉCANIQUE — Form                                             -->
    <!-- ============================================================ -->
    <record id="garage_mechanic_operation_form" model="ir.ui.view">
        <field name="name">garage.mechanic.operation.form</field>
        <field name="model">garage.mechanic.operation</field>
        <field name="arch" type="xml">
            <form string="Opération mécanique">
                <header>
                    <button name="action_start" type="object"
                            string="Démarrer" class="btn-primary"
                            invisible="state != 'todo'"/>
                    <button name="action_wait_parts" type="object"
                            string="Attente pièces"
                            invisible="state != 'in_progress'"/>
                    <button name="action_done" type="object"
                            string="Terminer" class="btn-primary"
                            invisible="state not in ('in_progress', 'waiting_parts')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="todo,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Opération">
                            <field name="name"/>
                            <field name="operation_category"/>
                            <field name="operation_type"/>
                            <field name="repair_order_id"/>
                        </group>
                        <group string="Exécution">
                            <field name="technician_id"/>
                            <field name="allocated_time"/>
                            <field name="actual_time"/>
                            <field name="is_scheduled_maintenance"/>
                            <field name="maintenance_plan_item_id"
                                   invisible="not is_scheduled_maintenance"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Diagnostic" name="page_diag"
                              invisible="operation_category != 'diagnostic'">
                            <group>
                                <field name="obd_codes"/>
                                <field name="obd_codes_cleared"/>
                            </group>
                            <field name="diagnosis_result"
                                   placeholder="Résultat du diagnostic..."/>
                        </page>
                        <page string="Pneumatiques" name="page_tires"
                              invisible="operation_category != 'tires'">
                            <group>
                                <group>
                                    <field name="tire_brand"/>
                                    <field name="tire_size"/>
                                    <field name="tire_dot"/>
                                </group>
                                <group>
                                    <field name="tire_tread_depth"/>
                                    <field name="tire_position"/>
                                </group>
                            </group>
                        </page>
                        <page string="Entretien" name="page_maint"
                              invisible="not is_scheduled_maintenance">
                            <group>
                                <field name="next_maintenance_km"/>
                                <field name="next_maintenance_date"/>
                            </group>
                        </page>
                        <page string="Notes" name="page_notes">
                            <field name="notes" placeholder="Notes techniques..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- MÉCANIQUE — Tree -->
