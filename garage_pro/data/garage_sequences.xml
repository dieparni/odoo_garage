<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_garage_vehicle" model="ir.sequence">
            <field name="name">Véhicule Garage</field>
            <field name="code">garage.vehicle</field>
            <field name="prefix">VEH/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_garage_claim" model="ir.sequence">
            <field name="name">Sinistre garage</field>
            <field name="code">garage.insurance.claim</field>
            <field name="prefix">SIN/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_garage_quotation" model="ir.sequence">
            <field name="name">Devis garage</field>
            <field name="code">garage.quotation</field>
            <field name="prefix">DEV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_garage_repair_order" model="ir.sequence">
            <field name="name">Ordre de réparation</field>
            <field name="code">garage.repair.order</field>
            <field name="prefix">OR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="seq_garage_subcontract_order" model="ir.sequence">
            <field name="name">Bon de sous-traitance</field>
            <field name="code">garage.subcontract.order</field>
            <field name="prefix">ST/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
