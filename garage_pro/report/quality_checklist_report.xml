<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Rapport QWeb : Checklist contrôle qualité
         ================================================================ -->

    <record id="action_report_garage_quality_checklist" model="ir.actions.report">
        <field name="name">Checklist qualité</field>
        <field name="model">garage.quality.checklist</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">garage_pro.report_garage_quality_checklist</field>
        <field name="report_file">garage_pro.report_garage_quality_checklist</field>
        <field name="binding_model_id" ref="model_garage_quality_checklist"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_garage_quality_checklist">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ===== TITRE ===== -->
                        <h2 class="mt-4">
                            Contrôle Qualité
                        </h2>
                        <h4 class="text-muted">
                            <span t-field="o.checklist_type"/> — OR <span t-field="o.repair_order_id.name"/>
                        </h4>

                        <!-- ===== RÉSULTAT GLOBAL ===== -->
                        <div class="mt-3 mb-3" t-if="o.overall_result">
                            <span t-if="o.overall_result == 'pass'"
                                  class="badge fs-6" style="background-color: #198754;">CONFORME</span>
                            <span t-if="o.overall_result == 'partial'"
                                  class="badge fs-6" style="background-color: #fd7e14;">PARTIELLEMENT CONFORME</span>
                            <span t-if="o.overall_result == 'fail'"
                                  class="badge fs-6" style="background-color: #dc3545;">NON CONFORME</span>
                        </div>

                        <!-- ===== INFO OR / VÉHICULE ===== -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="text-muted">Client</td>
                                        <td><span t-field="o.repair_order_id.customer_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Véhicule</td>
                                        <td>
                                            <span t-field="o.repair_order_id.vehicle_id.model_id.brand_id.name"/>
                                            <span t-field="o.repair_order_id.vehicle_id.model_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-muted">Immatriculation</td>
                                        <td><span t-field="o.repair_order_id.vehicle_id.license_plate"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr t-if="o.checked_by">
                                        <td class="text-muted">Contrôlé par</td>
                                        <td><span t-field="o.checked_by.name"/></td>
                                    </tr>
                                    <tr t-if="o.check_date">
                                        <td class="text-muted">Date du contrôle</td>
                                        <td><span t-field="o.check_date" t-options='{"widget": "datetime"}'/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ===== POINTS DE CONTRÔLE ===== -->
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th style="width: 5%;">#</th>
                                    <th style="width: 45%;">Point de contrôle</th>
                                    <th class="text-center" style="width: 15%;">Type</th>
                                    <th class="text-center" style="width: 15%;">Résultat</th>
                                    <th style="width: 20%;">Remarque</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.item_ids" t-as="item">
                                    <tr t-attf-style="#{item.result == 'nok' and 'background-color: #f8d7da;' or ''}">
                                        <td><t t-out="item_index + 1"/></td>
                                        <td><span t-field="item.name"/></td>
                                        <td class="text-center"><span t-field="item.check_type"/></td>
                                        <td class="text-center">
                                            <span t-if="item.result == 'ok'" style="color: #198754; font-weight: bold;">OK</span>
                                            <span t-if="item.result == 'nok'" style="color: #dc3545; font-weight: bold;">NOK</span>
                                            <span t-if="item.result == 'na'" class="text-muted">N/A</span>
                                            <span t-if="not item.result" class="text-muted">-</span>
                                        </td>
                                        <td>
                                            <span t-if="item.notes" t-field="item.notes"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ===== STATISTIQUES ===== -->
                        <div class="row mt-3">
                            <div class="col-12">
                                <t t-set="ok_count" t-value="len(o.item_ids.filtered(lambda i: i.result == 'ok'))"/>
                                <t t-set="nok_count" t-value="len(o.item_ids.filtered(lambda i: i.result == 'nok'))"/>
                                <t t-set="na_count" t-value="len(o.item_ids.filtered(lambda i: i.result == 'na'))"/>
                                <t t-set="pending_count" t-value="len(o.item_ids.filtered(lambda i: not i.result))"/>
                                <p>
                                    <strong>Résumé :</strong>
                                    <span style="color: #198754;"><t t-out="ok_count"/> OK</span> |
                                    <span style="color: #dc3545;"><t t-out="nok_count"/> NOK</span> |
                                    <span class="text-muted"><t t-out="na_count"/> N/A</span>
                                    <t t-if="pending_count">
                                        | <span class="text-warning"><t t-out="pending_count"/> en attente</span>
                                    </t>
                                </p>
                            </div>
                        </div>

                        <!-- ===== NOTES ===== -->
                        <div t-if="o.notes" class="mt-3">
                            <strong>Remarques générales :</strong>
                            <p t-field="o.notes"/>
                        </div>

                        <!-- ===== SIGNATURE ===== -->
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <p>Contrôlé par<br/><br/><br/>
                                _______________________________<br/>
                                <small>
                                    <span t-if="o.checked_by" t-field="o.checked_by.name"/>
                                </small></p>
                            </div>
                            <div class="col-6 text-center">
                                <p>Validé par (chef d'atelier)<br/><br/><br/>
                                _______________________________</p>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
